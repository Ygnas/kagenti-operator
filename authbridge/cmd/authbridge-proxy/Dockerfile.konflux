# AuthBridge proxy-sidecar combined image — Konflux downstream build.
# Build context: authbridge/ (needs access to authlib/ and cmd/authbridge-proxy/)
FROM registry.redhat.io/ubi9/go-toolset@sha256:d36470d5258da00f618b7aca9bdaab8e05134aa938bd6c42d9bd17d50ed45e76 AS builder
ARG TARGETOS
ARG TARGETARCH

USER root

WORKDIR /workspace
# Copy the Go Modules manifests and local dependency (authlib) first.
# authlib source is needed because cmd/authbridge-proxy/go.mod has a
# replace directive pointing to ../../authlib.
COPY authlib/ authlib/
COPY cmd/authbridge-proxy/go.mod cmd/authbridge-proxy/go.mod
COPY cmd/authbridge-proxy/go.sum cmd/authbridge-proxy/go.sum

# Cache deps before building and copying source so that we don't need to
# re-download as much and so that source changes don't invalidate our
# downloaded layer.
ENV GOWORK=off
WORKDIR /workspace/cmd/authbridge-proxy
RUN go mod download

# Copy the go source
WORKDIR /workspace
COPY cmd/authbridge-proxy/ cmd/authbridge-proxy/

# Build
WORKDIR /workspace/cmd/authbridge-proxy
RUN CGO_ENABLED=1 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64} \
    GOEXPERIMENT=strictfipsruntime \
    go build -a -o /authbridge-proxy .

# Use UBI minimal as the runtime base image
FROM registry.redhat.io/ubi9/ubi-minimal@sha256:ae09ecc3d754bc1726cbda3e2599cc7839e09fe1cc547ce173cf669b645be3cc

WORKDIR /
COPY --from=builder --chmod=755 /authbridge-proxy /usr/local/bin/authbridge-proxy
COPY --chmod=755 cmd/authbridge-proxy/entrypoint.sh /usr/local/bin/entrypoint.sh

USER 1001

EXPOSE 8080 8081 9091 9093 9094

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

LABEL com.redhat.component="odh-authbridge-proxy-rhel9" \
      name="rhoai/odh-authbridge-proxy-rhel9" \
      description="AI agent authentication proxy sidecar" \
      summary="AI agent authentication proxy sidecar" \
      maintainer="['managed-open-data-hub@redhat.com']" \
      io.openshift.expose-services="" \
      io.k8s.display-name="odh-authbridge-proxy-rhel9" \
      io.k8s.description="odh-authbridge-proxy-rhel9" \
      com.redhat.license_terms="https://www.redhat.com/licenses/Red_Hat_Standard_EULA_20191108.pdf"
